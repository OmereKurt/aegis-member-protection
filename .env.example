# Docker Compose defaults for local development.
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://aegis:aegis_password@db:5432/aegis
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000

BACKEND_PORT=8000
FRONTEND_PORT=3000
ENVIRONMENT=docker
