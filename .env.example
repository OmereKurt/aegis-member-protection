# Docker Compose defaults for local development.
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://aegis:aegis_password@db:5432/aegis
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-local-secret
SESSION_COOKIE_NAME=aegis_session
CSRF_COOKIE_NAME=aegis_csrf
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_DEMO_USERS_ENABLED=true
AI_ASSIST_ENABLED=true
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=aegis-mock-assist
AI_REQUEST_TIMEOUT_SECONDS=15
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000

BACKEND_PORT=8000
FRONTEND_PORT=3000
ENVIRONMENT=docker
