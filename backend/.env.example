# Leave DATABASE_URL unset to use the local SQLite fallback:
# sqlite:///./startup_scam_ops.db
DATABASE_URL=sqlite:///./startup_scam_ops.db

# Docker/Postgres example:
# DATABASE_URL=postgresql+psycopg://aegis:aegis_password@db:5432/aegis

FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

JWT_SECRET=replace-with-a-long-random-local-secret
SESSION_COOKIE_NAME=aegis_session
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_DEMO_USERS_ENABLED=true
SESSION_COOKIE_SECURE=false
